{
  "name": "session-5-page-builder-workshop",
  "version": "1.0.0",
  "private": false,
  "description": "Workshop baseline: a NestJS page builder for agent-driven pull requests.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prebuild": "prisma generate",
    "build": "nest build",
    "lint": "eslint . --max-warnings=0",
    "policy": "node scripts/policy.mjs",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:test": "node dist/main.js",
    "test": "npm run test:unit",
    "test:unit": "node tools/run-tests.mjs unit",
    "test:api": "node tools/run-tests.mjs api",
    "test:browser": "node tools/run-tests.mjs browser",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@prisma/adapter-pg": "7.8.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dotenv": "17.2.3",
    "pg": "8.16.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@nestjs/testing": "11.1.28",
    "@playwright/test": "1.61.1",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.15",
    "@types/pg": "8.15.6",
    "@types/supertest": "6.0.3",
    "eslint": "10.7.0",
    "jest": "29.7.0",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  }
}
